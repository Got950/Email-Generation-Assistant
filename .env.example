# OpenAI API Key (required)
OPENAI_API_KEY=sk-your-key-here

# Model overrides (optional). Defaults:
#   primary  = gpt-4o-mini  (advanced strategy)
#   baseline = gpt-3.5-turbo (weaker model, for A/B comparison)
#   judge    = gpt-4o       (stronger model, used for evaluation metrics and critic)
# Uncomment and change if your account lacks access to any of the defaults.
# PRIMARY_MODEL=gpt-4o-mini
# BASELINE_MODEL=gpt-3.5-turbo
# JUDGE_MODEL=gpt-4o

LOG_LEVEL=INFO
